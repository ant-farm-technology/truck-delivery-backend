# ── MySQL ──────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=root_secret_change_me
MYSQL_USER=truckdelivery
MYSQL_PASSWORD=truck_secret_change_me

# ── MongoDB ─────────────────────────────────────────────
MONGO_USER=truckdelivery
MONGO_PASSWORD=mongo_secret_change_me

# ── PostGIS ─────────────────────────────────────────────
POSTGIS_USER=truckdelivery
POSTGIS_PASSWORD=postgis_secret_change_me
POSTGIS_DATABASE=truck_spatial

# ── Redis ───────────────────────────────────────────────
REDIS_PASSWORD=redis_secret_change_me

# ── Grafana ─────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=grafana_secret_change_me

# ── MinIO (S3-compatible object storage) ─────────────────
MINIO_ROOT_USER=truckdelivery
MINIO_ROOT_PASSWORD=minio_secret_change_me

# ── Application Services ─────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-very-long-secret-key-min-32-chars

# ── Firebase FCM (Notification Service) ──────────────────
# Base64-encoded service account JSON from Firebase Console
# Leave empty to fall back to StubPushSender
FIREBASE_CREDENTIALS_JSON=

# ── Twilio SMS (Notification Service) ────────────────────
# Leave empty to fall back to StubSmsSender
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1234567890

# ── SMTP Email (Notification Service) ────────────────────
# Leave empty to fall back to StubEmailSender
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@truck-delivery.com
SMTP_FROM_NAME=Truck Delivery

# ── Notification Admin ────────────────────────────────────
NOTIFICATION_ADMIN_EMAIL=admin@truck-delivery.com

# ── VNPay Payment Gateway ─────────────────────────────────
# Leave empty to use COD-only mode
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=https://your-domain.com/api/v1/payments/webhook/vnpay
