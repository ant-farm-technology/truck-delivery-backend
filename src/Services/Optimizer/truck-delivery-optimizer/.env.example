SERVICE_NAME=truck-delivery-optimizer
PORT=8085
LOG_LEVEL=INFO

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
OTEL_ENABLED=true

# OR-Tools solver settings
SOLVER_TIMEOUT_SECONDS=10
SOLVER_FIRST_SOLUTION_STRATEGY=PATH_CHEAPEST_ARC
SOLVER_LOCAL_SEARCH_METAHEURISTIC=GUIDED_LOCAL_SEARCH

# Cost weights for objective: Distance×W1 + Time×W2 + Penalty×W3
WEIGHT_DISTANCE=1.0
WEIGHT_TIME=0.5
WEIGHT_PENALTY=1000.0
