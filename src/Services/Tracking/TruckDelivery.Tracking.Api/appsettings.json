{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Grafana.Loki" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "GrafanaLoki",
        "Args": {
          "uri": "http://loki:3100",
          "labels": [
            { "key": "service", "value": "tracking" }
          ],
          "propertiesAsLabels": [ "level" ]
        }
      }
    ]
  },

  "ConnectionStrings": {
    "Redis": "redis:6379",
    "MongoDB": "mongodb://mongo:27017"
  },

  "MongoDB": {
    "Database": "truck_tracking"
  },

  "Kafka": {
    "BootstrapServers": "kafka:9092",
    "GroupId": "tracking-service"
  },

  "Jwt": {
    "SecretKey": "change-this-to-a-very-long-secret-key-in-production",
    "Issuer": "truck-delivery",
    "Audience": "truck-delivery-api"
  },

  "Otel": {
    "Endpoint": "http://tempo:4317"
  },

  "AllowedHosts": "*"
}
