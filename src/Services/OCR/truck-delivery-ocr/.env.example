SERVICE_NAME=truck-delivery-ocr
PORT=8090
LOG_LEVEL=INFO

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
OTEL_ENABLED=true

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_CONSUMER_GROUP=ocr-service
KAFKA_TOPIC_DOCUMENTS_SUBMITTED=driver.documents.submitted
KAFKA_TOPIC_VERIFICATION_COMPLETED=ocr.driver.verification-completed

# OCR thresholds
OCR_CONFIDENCE_THRESHOLD_VERIFIED=0.85
OCR_CONFIDENCE_THRESHOLD_MANUAL_REVIEW=0.65

# HTTP client timeout (seconds)
HTTP_TIMEOUT_SECONDS=30
