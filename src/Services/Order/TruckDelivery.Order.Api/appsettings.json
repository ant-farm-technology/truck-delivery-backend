{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Grafana.Loki" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "GrafanaLoki",
        "Args": {
          "uri": "http://loki:3100",
          "labels": [
            { "key": "service", "value": "order" }
          ],
          "propertiesAsLabels": [ "level" ]
        }
      }
    ]
  },

  "ConnectionStrings": {
    "OrderDb": "Server=mysql;Port=3306;Database=truck_order;User=truckdelivery;Password=changeme;",
    "MySQL": "Server=mysql;Port=3306;Database=truck_order;User=truckdelivery;Password=changeme;",
    "Redis": "redis:6379"
  },

  "Kafka": {
    "BootstrapServers": "kafka:9092"
  },

  "Jwt": {
    "SecretKey": "change-this-to-a-very-long-secret-key-in-production",
    "Issuer": "truck-delivery",
    "Audience": "truck-delivery-api"
  },

  "Otel": {
    "Endpoint": "http://tempo:4317"
  },

  "Pricing": {
    "Motorbike": { "BaseFee": 15000, "RatePerKm": 3000,  "ThresholdKg": 30,   "SurchargePerKg": 500 },
    "Van":       { "BaseFee": 30000, "RatePerKm": 5000,  "ThresholdKg": 500,  "SurchargePerKg": 300 },
    "Truck3T":   { "BaseFee": 50000, "RatePerKm": 8000,  "ThresholdKg": 1500, "SurchargePerKg": 200 },
    "Truck5T":   { "BaseFee": 80000, "RatePerKm": 12000, "ThresholdKg": 2500, "SurchargePerKg": 150 },
    "Truck10T":  { "BaseFee": 120000,"RatePerKm": 18000, "ThresholdKg": 5000, "SurchargePerKg": 120 },
    "Truck15T":  { "BaseFee": 180000,"RatePerKm": 25000, "ThresholdKg": 7500, "SurchargePerKg": 100 }
  },

  "AllowedHosts": "*"
}
