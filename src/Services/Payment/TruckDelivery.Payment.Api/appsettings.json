{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Grafana.Loki" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "GrafanaLoki",
        "Args": {
          "uri": "http://loki:3100",
          "labels": [
            { "key": "service", "value": "payment" }
          ],
          "propertiesAsLabels": [ "level" ]
        }
      }
    ]
  },

  "ConnectionStrings": {
    "PaymentDb": "Server=mysql;Port=3306;Database=truck_payment;User=truckdelivery;Password=changeme;",
    "MySQL": "Server=mysql;Port=3306;Database=truck_payment;User=truckdelivery;Password=changeme;",
    "Redis": "redis:6379"
  },

  "Kafka": {
    "BootstrapServers": "kafka:9092",
    "GroupId": "payment-service"
  },

  "Jwt": {
    "SecretKey": "change-this-to-a-very-long-secret-key-in-production",
    "Issuer": "truck-delivery",
    "Audience": "truck-delivery-api"
  },

  "Otel": {
    "Endpoint": "http://tempo:4317"
  },

  "VnPay": {
    "TmnCode": "",
    "HashSecret": "",
    "PaymentUrl": "https://sandbox.vnpayment.vn/paymentv2/vpcpay.html",
    "ReturnUrl": "http://localhost:8089/api/v1/payments/webhook/vnpay"
  },

  "AllowedHosts": "*"
}
