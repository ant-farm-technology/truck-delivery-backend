{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.AspNetCore": "Information",
        "Yarp": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {CorrelationId} {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },

  "Jwt": {
    "Authority": "http://localhost:5200",
    "Audience": "truck-delivery-api"
  },

  "Otel": {
    "Endpoint": "http://localhost:4317"
  },

  "ReverseProxy": {
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "primary": { "Address": "http://localhost:5200/" }
        }
      },
      "order-cluster": {
        "Destinations": {
          "primary": { "Address": "http://localhost:5201/" }
        }
      },
      "driver-cluster": {
        "Destinations": {
          "primary": { "Address": "http://localhost:5202/" }
        }
      },
      "shipment-cluster": {
        "Destinations": {
          "primary": { "Address": "http://localhost:5203/" }
        }
      },
      "tracking-cluster": {
        "Destinations": {
          "primary": { "Address": "http://localhost:5204/" }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "primary": { "Address": "http://localhost:5205/" }
        }
      },
      "payment-cluster": {
        "Destinations": {
          "primary": { "Address": "http://localhost:5206/" }
        }
      },
      "route-service-cluster": {
        "Destinations": {
          "primary": { "Address": "http://localhost:8081/" }
        }
      },
      "optimizer-cluster": {
        "Destinations": {
          "primary": { "Address": "http://localhost:8082/" }
        }
      }
    }
  }
}
