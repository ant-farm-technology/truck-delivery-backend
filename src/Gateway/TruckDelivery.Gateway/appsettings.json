{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Grafana.Loki" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {CorrelationId} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "GrafanaLoki",
        "Args": {
          "uri": "http://loki:3100",
          "labels": [
            { "key": "service", "value": "gateway" },
            { "key": "env", "value": "development" }
          ],
          "propertiesAsLabels": [ "level" ]
        }
      }
    ]
  },

  "Jwt": {
    "Authority": "http://identity-service:8080",
    "Audience": "truck-delivery-api"
  },

  "Otel": {
    "Endpoint": "http://tempo:4317"
  },

  "IpRateLimiting": {
    "EnableEndpointRateLimiting": false,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 300
      },
      {
        "Endpoint": "*",
        "Period": "1h",
        "Limit": 5000
      }
    ]
  },

  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/api/v1/auth/{**catch-all}"
        }
      },
      "order-route": {
        "ClusterId": "order-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/v1/orders/{**catch-all}"
        }
      },
      "driver-route": {
        "ClusterId": "driver-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/v1/drivers/{**catch-all}"
        }
      },
      "shipment-route": {
        "ClusterId": "shipment-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/v1/shipments/{**catch-all}"
        }
      },
      "tracking-route": {
        "ClusterId": "tracking-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/v1/tracking/{**catch-all}"
        }
      },
      "tracking-ws-route": {
        "ClusterId": "tracking-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/hubs/tracking/{**catch-all}"
        }
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/v1/notifications/{**catch-all}"
        }
      },
      "payment-route": {
        "ClusterId": "payment-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/v1/payments/{**catch-all}"
        }
      },
      "route-service-route": {
        "ClusterId": "route-service-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/v1/routes/{**catch-all}"
        }
      },
      "optimizer-route": {
        "ClusterId": "optimizer-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/v1/optimize/{**catch-all}"
        }
      },
      "vehicle-route": {
        "ClusterId": "driver-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/v1/vehicles/{**catch-all}"
        }
      },
      "admin-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/v1/admin/{**catch-all}"
        }
      },
      "analytics-route": {
        "ClusterId": "analytics-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/v1/analytics/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "primary": { "Address": "http://identity-service:8080/" }
        }
      },
      "order-cluster": {
        "Destinations": {
          "primary": { "Address": "http://order-service:8080/" }
        }
      },
      "driver-cluster": {
        "Destinations": {
          "primary": { "Address": "http://driver-service:8080/" }
        }
      },
      "shipment-cluster": {
        "Destinations": {
          "primary": { "Address": "http://shipment-service:8080/" }
        }
      },
      "tracking-cluster": {
        "Destinations": {
          "primary": { "Address": "http://tracking-service:8080/" }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "primary": { "Address": "http://notification-service:8080/" }
        }
      },
      "payment-cluster": {
        "Destinations": {
          "primary": { "Address": "http://payment-service:8080/" }
        }
      },
      "route-service-cluster": {
        "Destinations": {
          "primary": { "Address": "http://route-service:8081/" }
        }
      },
      "optimizer-cluster": {
        "Destinations": {
          "primary": { "Address": "http://optimizer-service:8082/" }
        }
      },
      "analytics-cluster": {
        "Destinations": {
          "primary": { "Address": "http://analytics-service:8080/" }
        }
      }
    }
  },

  "AllowedHosts": "*"
}
